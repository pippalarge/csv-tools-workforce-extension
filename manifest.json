{
  "envSchema": {
    "type": "object",
    "properties": {}
  },
  "actions": [
    {
      "name": "csvToRows",
      "label": "CSV to Rows",
      "description": "Parse a CSV string into rows (an array of header-keyed objects). The entry point when your tabular data arrives as CSV text.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "csv": {
            "type": "string",
            "title": "CSV text",
            "description": "The CSV string to parse."
          },
          "delimiter": {
            "type": "string",
            "title": "Delimiter",
            "description": "Field delimiter. Defaults to a comma."
          }
        },
        "required": [
          "csv"
        ]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "rows": {
            "type": "array",
            "title": "Rows",
            "items": {
              "type": "object"
            }
          },
          "count": {
            "type": "number",
            "title": "Row count"
          }
        }
      }
    },
    {
      "name": "rowsToCsv",
      "label": "Rows to CSV",
      "description": "Serialise rows into a CSV string. Use to export rows for a system that wants CSV text.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "rows": {
            "type": "array",
            "title": "Rows",
            "items": {
              "type": "object"
            }
          },
          "columns": {
            "type": "array",
            "title": "Columns",
            "description": "Optional column order. Omit to use the union of keys.",
            "items": {
              "type": "string"
            }
          },
          "delimiter": {
            "type": "string",
            "title": "Delimiter",
            "description": "Field delimiter. Defaults to a comma."
          }
        },
        "required": [
          "rows"
        ]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "csv": {
            "type": "string",
            "title": "CSV text"
          },
          "count": {
            "type": "number",
            "title": "Row count"
          }
        }
      }
    },
    {
      "name": "jsonToRows",
      "label": "JSON to Rows",
      "description": "Parse a JSON string into rows. Accepts a JSON array, or an object wrapping an array under a rows key.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "json": {
            "type": "string",
            "title": "JSON text",
            "description": "The JSON string to parse."
          }
        },
        "required": [
          "json"
        ]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "rows": {
            "type": "array",
            "title": "Rows",
            "items": {
              "type": "object"
            }
          },
          "count": {
            "type": "number",
            "title": "Row count"
          }
        }
      }
    },
    {
      "name": "rowsToJson",
      "label": "Rows to JSON",
      "description": "Serialise rows into a JSON string.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "rows": {
            "type": "array",
            "title": "Rows",
            "items": {
              "type": "object"
            }
          },
          "pretty": {
            "type": "boolean",
            "title": "Pretty print",
            "description": "Indent the JSON for readability. Defaults to false."
          }
        },
        "required": [
          "rows"
        ]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "json": {
            "type": "string",
            "title": "JSON text"
          },
          "count": {
            "type": "number",
            "title": "Row count"
          }
        }
      }
    },
    {
      "name": "filterRows",
      "label": "Filter Rows",
      "description": "Keep only the rows where a column meets a condition. Operators: eq, ne, gt, gte, lt, lte, contains, empty, notEmpty.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "rows": {
            "type": "array",
            "title": "Rows",
            "items": {
              "type": "object"
            }
          },
          "column": {
            "type": "string",
            "title": "Column",
            "description": "The column to test."
          },
          "operator": {
            "type": "string",
            "title": "Operator",
            "description": "eq, ne, gt, gte, lt, lte, contains, empty, notEmpty. Defaults to notEmpty."
          },
          "value": {
            "type": "string",
            "title": "Value",
            "description": "The value to compare against."
          }
        },
        "required": [
          "rows",
          "column"
        ]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "rows": {
            "type": "array",
            "title": "Kept rows",
            "items": {
              "type": "object"
            }
          },
          "count": {
            "type": "number",
            "title": "Kept count"
          },
          "removed": {
            "type": "number",
            "title": "Removed count"
          }
        }
      }
    },
    {
      "name": "sortRows",
      "label": "Sort Rows",
      "description": "Sort rows by one or more columns, ascending or descending. Numeric-aware (numbers sort as numbers).",
      "inputSchema": {
        "type": "object",
        "properties": {
          "rows": {
            "type": "array",
            "title": "Rows",
            "items": {
              "type": "object"
            }
          },
          "by": {
            "type": "array",
            "title": "Sort by",
            "description": "Column name(s) to sort by, in priority order.",
            "items": {
              "type": "string"
            }
          },
          "order": {
            "type": "string",
            "title": "Order",
            "description": "asc (default) or desc."
          }
        },
        "required": [
          "rows",
          "by"
        ]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "rows": {
            "type": "array",
            "title": "Sorted rows",
            "items": {
              "type": "object"
            }
          },
          "count": {
            "type": "number",
            "title": "Row count"
          }
        }
      }
    },
    {
      "name": "selectColumns",
      "label": "Select Columns",
      "description": "Keep only the listed columns, in the order given. Everything else is dropped.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "rows": {
            "type": "array",
            "title": "Rows",
            "items": {
              "type": "object"
            }
          },
          "columns": {
            "type": "array",
            "title": "Columns",
            "description": "The columns to keep, in order.",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "rows",
          "columns"
        ]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "rows": {
            "type": "array",
            "title": "Rows",
            "items": {
              "type": "object"
            }
          },
          "count": {
            "type": "number",
            "title": "Row count"
          }
        }
      }
    },
    {
      "name": "dropColumns",
      "label": "Drop Columns",
      "description": "Remove the listed columns; every other column passes through. The complement of Select Columns.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "rows": {
            "type": "array",
            "title": "Rows",
            "items": {
              "type": "object"
            }
          },
          "columns": {
            "type": "array",
            "title": "Columns",
            "description": "The columns to remove.",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "rows",
          "columns"
        ]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "rows": {
            "type": "array",
            "title": "Rows",
            "items": {
              "type": "object"
            }
          },
          "count": {
            "type": "number",
            "title": "Row count"
          }
        }
      }
    },
    {
      "name": "renameColumns",
      "label": "Rename Columns",
      "description": "Rename columns using an old-name to new-name mapping. Remap headers to the field names a downstream step expects.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "rows": {
            "type": "array",
            "title": "Rows",
            "items": {
              "type": "object"
            }
          },
          "mapping": {
            "type": "object",
            "title": "Mapping",
            "description": "An object of { oldName: newName }."
          },
          "dropUnmapped": {
            "type": "boolean",
            "title": "Drop unmapped",
            "description": "Drop columns not in the mapping. Defaults to false."
          }
        },
        "required": [
          "rows",
          "mapping"
        ]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "rows": {
            "type": "array",
            "title": "Rows",
            "items": {
              "type": "object"
            }
          },
          "count": {
            "type": "number",
            "title": "Row count"
          }
        }
      }
    },
    {
      "name": "addColumn",
      "label": "Add Column",
      "description": "Add a new column to every row — either a constant value, or a template that fills in other columns with {Column} tokens, e.g. {Brand} {Title}.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "rows": {
            "type": "array",
            "title": "Rows",
            "items": {
              "type": "object"
            }
          },
          "name": {
            "type": "string",
            "title": "Column name",
            "description": "The name of the new column."
          },
          "value": {
            "type": "string",
            "title": "Value",
            "description": "A constant value for the new column."
          },
          "template": {
            "type": "string",
            "title": "Template",
            "description": "A template using {Column} tokens. Wins over Value if set."
          }
        },
        "required": [
          "rows",
          "name"
        ]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "rows": {
            "type": "array",
            "title": "Rows",
            "items": {
              "type": "object"
            }
          },
          "count": {
            "type": "number",
            "title": "Row count"
          }
        }
      }
    },
    {
      "name": "pluckColumn",
      "label": "Pluck Column",
      "description": "Return a single column's values as a flat list (e.g. the allowed values of an attribute). Optional distinct and drop-empty.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "rows": {
            "type": "array",
            "title": "Rows",
            "items": {
              "type": "object"
            }
          },
          "column": {
            "type": "string",
            "title": "Column",
            "description": "The column to pluck."
          },
          "distinct": {
            "type": "boolean",
            "title": "Distinct",
            "description": "Drop duplicate values. Defaults to false."
          },
          "dropEmpty": {
            "type": "boolean",
            "title": "Drop empty",
            "description": "Drop blank values. Defaults to true."
          }
        },
        "required": [
          "rows",
          "column"
        ]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "values": {
            "type": "array",
            "title": "Values",
            "items": {}
          },
          "count": {
            "type": "number",
            "title": "Value count"
          }
        }
      }
    },
    {
      "name": "cleanRows",
      "label": "Clean Rows",
      "description": "Tidy and coerce values: trim whitespace, convert chosen columns to numbers or booleans, and fill blanks with a default.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "rows": {
            "type": "array",
            "title": "Rows",
            "items": {
              "type": "object"
            }
          },
          "trim": {
            "type": "boolean",
            "title": "Trim",
            "description": "Trim whitespace from strings. Defaults to true."
          },
          "numericColumns": {
            "type": "array",
            "title": "Numeric columns",
            "description": "Columns to convert to numbers.",
            "items": {
              "type": "string"
            }
          },
          "booleanColumns": {
            "type": "array",
            "title": "Boolean columns",
            "description": "Columns to convert to booleans.",
            "items": {
              "type": "string"
            }
          },
          "emptyDefault": {
            "type": "string",
            "title": "Empty default",
            "description": "Value to use for blank cells."
          }
        },
        "required": [
          "rows"
        ]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "rows": {
            "type": "array",
            "title": "Rows",
            "items": {
              "type": "object"
            }
          },
          "count": {
            "type": "number",
            "title": "Row count"
          }
        }
      }
    },
    {
      "name": "validateRows",
      "label": "Validate Rows",
      "description": "Split rows into valid and invalid based on required (non-empty) columns. Invalid rows carry an _errors list.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "rows": {
            "type": "array",
            "title": "Rows",
            "items": {
              "type": "object"
            }
          },
          "required": {
            "type": "array",
            "title": "Required columns",
            "description": "Columns that must be non-empty.",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "rows"
        ]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "valid": {
            "type": "array",
            "title": "Valid rows",
            "items": {
              "type": "object"
            }
          },
          "invalid": {
            "type": "array",
            "title": "Invalid rows",
            "items": {
              "type": "object"
            }
          },
          "validCount": {
            "type": "number",
            "title": "Valid count"
          },
          "invalidCount": {
            "type": "number",
            "title": "Invalid count"
          }
        }
      }
    },
    {
      "name": "dedupeRows",
      "label": "Deduplicate Rows",
      "description": "Remove duplicate rows by one or more key columns. Keeps the first occurrence.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "rows": {
            "type": "array",
            "title": "Rows",
            "items": {
              "type": "object"
            }
          },
          "key": {
            "type": "array",
            "title": "Key columns",
            "description": "Column(s) that identify a duplicate.",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "rows",
          "key"
        ]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "rows": {
            "type": "array",
            "title": "Rows",
            "items": {
              "type": "object"
            }
          },
          "count": {
            "type": "number",
            "title": "Row count"
          },
          "duplicatesRemoved": {
            "type": "number",
            "title": "Duplicates removed"
          }
        }
      }
    },
    {
      "name": "joinRows",
      "label": "Join Rows",
      "description": "Join two row sets on a key column to attach reference data to records — a VLOOKUP across datasets (e.g. add taxonomy or synonyms to product rows). type: left (keep unmatched) or inner (drop unmatched).",
      "inputSchema": {
        "type": "object",
        "properties": {
          "leftRows": {
            "type": "array",
            "title": "Left rows",
            "items": {
              "type": "object"
            }
          },
          "rightRows": {
            "type": "array",
            "title": "Right rows",
            "items": {
              "type": "object"
            }
          },
          "leftKey": {
            "type": "string",
            "title": "Left key",
            "description": "The key column in the left rows."
          },
          "rightKey": {
            "type": "string",
            "title": "Right key",
            "description": "The key column in the right rows. Defaults to the left key."
          },
          "type": {
            "type": "string",
            "title": "Join type",
            "description": "left (default) or inner."
          },
          "prefix": {
            "type": "string",
            "title": "Right prefix",
            "description": "Optional prefix added to right columns to avoid clashes."
          }
        },
        "required": [
          "leftRows",
          "rightRows",
          "leftKey"
        ]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "rows": {
            "type": "array",
            "title": "Joined rows",
            "items": {
              "type": "object"
            }
          },
          "count": {
            "type": "number",
            "title": "Row count"
          },
          "matched": {
            "type": "number",
            "title": "Matched"
          },
          "unmatched": {
            "type": "number",
            "title": "Unmatched"
          }
        }
      }
    },
    {
      "name": "concatRows",
      "label": "Concatenate Rows",
      "description": "Stack two row sets into one (union). Useful for merging several tabs loaded with Load Tabs.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "rows": {
            "type": "array",
            "title": "First rows",
            "items": {
              "type": "object"
            }
          },
          "rows2": {
            "type": "array",
            "title": "Second rows",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "rows",
          "rows2"
        ]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "rows": {
            "type": "array",
            "title": "Rows",
            "items": {
              "type": "object"
            }
          },
          "count": {
            "type": "number",
            "title": "Row count"
          }
        }
      }
    },
    {
      "name": "chunkRows",
      "label": "Chunk Rows into Batches",
      "description": "Split rows into batches of a given size. Process one batch per run to stay under a downstream per-execution API limit.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "rows": {
            "type": "array",
            "title": "Rows",
            "items": {
              "type": "object"
            }
          },
          "size": {
            "type": "number",
            "title": "Batch size",
            "description": "Rows per batch. Defaults to 10."
          }
        },
        "required": [
          "rows"
        ]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "chunks": {
            "type": "array",
            "title": "Chunks",
            "items": {
              "type": "array",
              "items": {
                "type": "object"
              }
            }
          },
          "chunkCount": {
            "type": "number",
            "title": "Chunk count"
          },
          "rowCount": {
            "type": "number",
            "title": "Row count"
          }
        }
      }
    },
    {
      "name": "summarizeRows",
      "label": "Summarize Rows",
      "description": "Per-column stats: non-empty count, distinct count, and numeric min/max/sum where values are numbers.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "rows": {
            "type": "array",
            "title": "Rows",
            "items": {
              "type": "object"
            }
          },
          "columns": {
            "type": "array",
            "title": "Columns",
            "description": "Optional subset of columns to summarise.",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "rows"
        ]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "rowCount": {
            "type": "number",
            "title": "Row count"
          },
          "columnCount": {
            "type": "number",
            "title": "Column count"
          },
          "columns": {
            "type": "array",
            "title": "Per-column stats",
            "items": {
              "type": "object"
            }
          }
        }
      }
    }
  ]
}
